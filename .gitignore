# Rust
/server/target/
**/*.rs.bk

# Node / Bun (React frontend)
/console/node_modules/
/console/dist/
/console/.vite/

# Environment & secrets
.env
.env.*
!.env.example

# IDE
.idea/
.vscode/
.obsidian/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log

# DuckDB local data
server/data/
*.duckdb
*.duckdb.wal

# Legacy hand-distributed pcap fixtures (large; not checked in). The curated,
# scrubbed corpus under testdata/pcaps/corpus/ IS committed (via git-LFS — see
# .gitattributes) and is deliberately NOT matched by this top-level-only glob.
/testdata/pcaps/*.pcap
# Scratch area for raw, unscrubbed captures — never commit these.
/testdata/pcaps/raw/

# Build artifacts
*.o
*.so
*.dylib

# Python bytecode (scripts/pr-review, scripts/lint helpers)
__pycache__/
*.pyc

# Demo server live config (seeded from default.toml, maintained per-env)
/server/config/demo.toml

.playwright-mcp/
.claude/settings.local.json
.claude/worktrees/
.superpowers
.worktrees/

# Transient clone of the internal Olympus agent repo, created by the agent-loop
# runner. Never commit it — a checked-in gitlink breaks public clones (no
# .gitmodules) and its .git/config holds a runner credential.
/_agentops/
/_agentops

/logs/
