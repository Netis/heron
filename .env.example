# TokenScope environment configuration
# Copy to .env.local for local overrides (never commit .env.local)

# Demo server (Linux VM running TokenScope + cliproxyapi)
DEMO_HOST=demo-server-ip
DEMO_USER=ts
DEMO_URL=http://demo-server-ip:3000/

# SSH key for demo server access
DEMO_SSH_KEY=~/.ssh/id_ed25519_tokenscope

# Optional SSH jump host — set only if DEMO_HOST is not directly reachable.
# Leave DEMO_JUMP_HOST empty to connect directly.
DEMO_JUMP_HOST=
DEMO_JUMP_USER=
DEMO_JUMP_KEY=

# Branch to build for demo (cross-compile + deploy)
DEMO_BRANCH=main
